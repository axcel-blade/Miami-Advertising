---
import logoSrc from '../assets/images/logo.png';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title       = 'Miami Advertising – Empower Your Needs',
  description = 'Miami Advertising is a regional advertising, production, marketing and event management company based in Sharjah, UAE. Vehicle wraps, signage, exhibition booths, visual merchandising and more.',
  keywords    = 'advertising agency Sharjah, vehicle wraps UAE, signage Sharjah, exhibition booths UAE, visual merchandising, branding agency UAE, Miami Advertising, outdoor advertising',
  ogImage     = logoSrc.src,
  canonical   = Astro.url.href,
} = Astro.props;

const siteName = 'Miami Advertising';
const siteUrl  = 'https://www.miamiadv.ae';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  url: siteUrl,
  logo: `${siteUrl}/images/logo.png`,
  description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Industrial Area 13, Shed No. 3',
    addressLocality: 'Sharjah',
    addressCountry: 'AE',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+971-6-542-0994',
    contactType: 'customer service',
    email: 'info@miamiadv.ae',
    availableLanguage: ['English', 'Arabic'],
  },
  areaServed: {
    '@type': 'GeoCircle',
    geoMidpoint: { '@type': 'GeoCoordinates', latitude: 25.3, longitude: 55.4 },
    geoRadius: '200000',
  },
  knowsAbout: [
    'Advertising', 'Branding', 'Vehicle Graphics', 'Signage', 'Exhibition Booths',
    'Visual Merchandising', 'Digital Printing', 'Event Management',
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords"    content={keywords} />
    <meta name="author"      content={siteName} />
    <meta name="robots"      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical"    href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content={siteName} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:image"       content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:alt"   content={`${siteName} logo`} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:locale"      content="en_AE" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${siteUrl}${ogImage}`} />
    <meta name="twitter:image:alt"   content={`${siteName} logo`} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet" />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* ── Miami Advertising brand colours extracted from logomark-and-wordmark.png ── */
    --clr-brand-pink:    #b50055;
    --clr-brand-magenta: #9d0057;
    --clr-brand-purple:  #631985;
    --clr-brand-indigo:  #401d81;
    --clr-brand-navy:    #004997;
    --clr-brand-blue:    #00629e;
    --clr-brand-teal:    #006f6b;
    --clr-brand-green:   #00ab44;
    --clr-brand-lime:    #4fad02;
    --clr-brand-yellow:  #f3cf00;
    --clr-brand-red:     #e00000;

    /* Full-spectrum brand gradient (mirrors the logo's colour wheel) */
    --gradient-brand: linear-gradient(135deg,
      #b50055 0%, #9d0057 10%, #631985 22%, #401d81 34%,
      #004997 46%, #00629e 56%, #006f6b 66%, #00ab44 76%,
      #4fad02 84%, #f3cf00 91%, #e00000 100%);

    /* ── Theme aliases ── */
    --clr-red:    #e00000;   /* Advertising division — logo red   */
    --clr-green:  #00ab44;   /* Production division  — logo green */
    --clr-orange: #f3cf00;   /* Marketing division   — logo gold  */
    --clr-accent: #b50055;   /* Primary UI accent    — logo pink  */

    /* ── Neutral scale ── */
    --clr-dark:   #111111;
    --clr-mid:    #444444;
    --clr-light:  #f5f5f5;
    --clr-white:  #ffffff;

    /* ── Typography & layout ── */
    --font-body:  'Inter', sans-serif;
    --font-head:  'Rajdhani', sans-serif;
    --max-w:      1280px;
    --section-py: 80px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    color: var(--clr-dark);
    background: var(--clr-white);
    line-height: 1.6;
    overflow-x: hidden;
  }

  img { max-width: 100%; display: block; }

  a { color: inherit; text-decoration: none; }

  .container {
    width: 100%;
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: 24px;
  }

  .section-label {
    font-family: var(--font-head);
    font-size: 13px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--clr-accent);
    display: block;
    margin-bottom: 10px;
  }

  .section-title {
    font-family: var(--font-head);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.1;
    color: var(--clr-dark);
  }

  .section-title span { color: var(--clr-accent); }

  .section-body {
    font-size: 16px;
    color: var(--clr-mid);
    max-width: 640px;
    line-height: 1.8;
  }

  /* Scroll reveal utility */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity .6s ease, transform .6s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: none;
  }
</style>
