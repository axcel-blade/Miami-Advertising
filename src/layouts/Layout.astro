---
import logoSrc from '../assets/Miami logo-01.svg';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title       = 'Miami Advertising – Empower Your Needs | Dubai, UAE',
  description = 'Miami Advertising is a Dubai-based advertising, production, marketing and event management company. Vehicle wraps, signage, exhibition booths, visual merchandising and branding for Pizza Hut, KFC, Hardees and more.',
  keywords    = 'advertising agency Dubai, vehicle wraps UAE, signage Dubai, exhibition booths UAE, visual merchandising, branding agency Dubai, Miami Advertising, outdoor advertising Dubai, KFC branding, Pizza Hut vehicle wrap',
  ogImage     = logoSrc.src,
  canonical   = Astro.url.href,
} = Astro.props;

const siteName = 'Miami Advertising';
const siteUrl  = 'https://miamiadv.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  url: siteUrl,
  logo: `${siteUrl}/images/logo.png`,
  description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Industrial Area 13, Shed No. 3',
    addressLocality: 'Dubai',
    addressCountry: 'AE',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+971-6-542-0994',
    contactType: 'customer service',
    email: 'info@miamiadv.ae',
    availableLanguage: ['English', 'Arabic'],
  },
  areaServed: {
    '@type': 'GeoCircle',
    geoMidpoint: { '@type': 'GeoCoordinates', latitude: 25.3, longitude: 55.4 },
    geoRadius: '200000',
  },
  knowsAbout: [
    'Advertising', 'Branding', 'Vehicle Graphics', 'Signage', 'Exhibition Booths',
    'Visual Merchandising', 'Digital Printing', 'Event Management',
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords"    content={keywords} />
    <meta name="author"      content={siteName} />
    <meta name="robots"      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical"    href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content={siteName} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:image"       content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:alt"   content={`${siteName} logo`} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:locale"      content="en_AE" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${siteUrl}${ogImage}`} />
    <meta name="twitter:image:alt"   content={`${siteName} logo`} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet" />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <slot />

    <!-- Floating WhatsApp button -->
    <a
      href="https://wa.me/971566302686"
      class="whatsapp-fab"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Chat on WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="#fff">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* ── Miami Advertising brand colours extracted from logomark-and-wordmark.png ── */
    --clr-brand-pink:    #b50055;
    --clr-brand-magenta: #9d0057;
    --clr-brand-purple:  #631985;
    --clr-brand-indigo:  #401d81;
    --clr-brand-navy:    #004997;
    --clr-brand-blue:    #00629e;
    --clr-brand-teal:    #006f6b;
    --clr-brand-green:   #00ab44;
    --clr-brand-lime:    #4fad02;
    --clr-brand-yellow:  #f3cf00;
    --clr-brand-red:     #e00000;

    /* Full-spectrum brand gradient (mirrors the logo's colour wheel) */
    --gradient-brand: linear-gradient(135deg,
      #b50055 0%, #9d0057 10%, #631985 22%, #401d81 34%,
      #004997 46%, #00629e 56%, #006f6b 66%, #00ab44 76%,
      #4fad02 84%, #f3cf00 91%, #e00000 100%);

    /* ── Theme aliases ── */
    --clr-red:    #e00000;   /* Advertising division — logo red   */
    --clr-green:  #00ab44;   /* Production division  — logo green */
    --clr-orange: #f3cf00;   /* Marketing division   — logo gold  */
    --clr-accent: #b50055;   /* Primary UI accent    — logo pink  */

    /* ── Neutral scale ── */
    --clr-dark:   #111111;
    --clr-mid:    #444444;
    --clr-light:  #f5f5f5;
    --clr-white:  #ffffff;

    /* ── Typography & layout ── */
    --font-body:  'Inter', sans-serif;
    --font-head:  'Rajdhani', sans-serif;
    --max-w:      1280px;
    --section-py: 80px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    color: var(--clr-dark);
    background: var(--clr-white);
    line-height: 1.6;
    overflow-x: hidden;
  }

  img { max-width: 100%; display: block; }

  a { color: inherit; text-decoration: none; }

  .container {
    width: 100%;
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: 24px;
  }

  .section-label {
    font-family: var(--font-head);
    font-size: 13px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--clr-accent);
    display: block;
    margin-bottom: 10px;
  }

  .section-title {
    font-family: var(--font-head);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.1;
    color: var(--clr-dark);
  }

  .section-title span { color: var(--clr-accent); }

  .section-body {
    font-size: 16px;
    color: var(--clr-mid);
    max-width: 640px;
    line-height: 1.8;
  }

  /* WhatsApp floating button */
  .whatsapp-fab {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 999;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #25d366;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(37,211,102,.45);
    transition: transform .2s, box-shadow .2s;
  }
  .whatsapp-fab:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 24px rgba(37,211,102,.6);
  }

  /* Scroll reveal utility */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity .6s ease, transform .6s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: none;
  }
</style>
