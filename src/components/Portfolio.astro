---
const rawMiami = import.meta.glob<{ default: { src: string } }>(
  '../assets/miami/**/*.{jpg,jpeg,JPG,JPEG,png,PNG}',
  { eager: true }
);

function clientImgs(folder: string, label: string, cat: string) {
  return Object.entries(rawMiami)
    .filter(([k]) => k.includes(folder))
    .map(([, v]) => ({ src: v.default.src, alt: `${label} — Miami Advertising work`, cat }));
}

const pizzaHutImgs  = clientImgs('/pizza hut/',  'Pizza Hut',    'pizza-hut');
const kfcImgs       = clientImgs('/kfc/',         'KFC',          'kfc');
const hardeesImgs   = clientImgs('/Hardees/',     'Hardees',      'hardees');
const otherImgs     = clientImgs('/other/',       'Client',       'other');

const allImages = [...pizzaHutImgs, ...kfcImgs, ...hardeesImgs, ...otherImgs];

const categories = [
  { id: 'all',       label: 'All Work' },
  { id: 'pizza-hut', label: 'Pizza Hut' },
  { id: 'kfc',       label: 'KFC' },
  { id: 'hardees',   label: 'Hardees' },
  { id: 'other',     label: 'Other' },
];
---

<section class="portfolio" id="portfolio">
  <div class="container">
    <div class="portfolio-header reveal">
      <span class="section-label">Our Work</span>
      <h2 class="section-title">Our <span>Portfolio</span></h2>
      <p class="section-body">Vehicle graphics, signage, store branding and production work for leading food & retail brands across Dubai and the UAE.</p>
    </div>

    <div class="filter-bar reveal">
      {categories.map(c => (
        <button class={`filter-btn${c.id === 'all' ? ' active' : ''}`} data-cat={c.id}>
          {c.label}
        </button>
      ))}
    </div>

    <div class="portfolio-grid" id="portfolio-grid">
      {allImages.map(img => (
        <div class="pf-item reveal" data-cat={img.cat}>
          <div class="pf-img-wrap">
            <img src={img.src} alt={img.alt} loading="lazy" />
            <div class="pf-overlay">
              <span>{img.alt}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .portfolio {
    padding: var(--section-py) 0;
    background: var(--clr-light);
  }

  .portfolio-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .portfolio-header .section-body { margin-inline: auto; }

  .filter-bar {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .filter-btn {
    padding: 8px 20px;
    border: 1.5px solid #ddd;
    background: transparent;
    border-radius: 40px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    color: var(--clr-mid);
    transition: all .2s;
    letter-spacing: .5px;
  }

  .filter-btn:hover, .filter-btn.active {
    background: var(--clr-accent);
    border-color: var(--clr-accent);
    color: #fff;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .pf-item { border-radius: 6px; overflow: hidden; }

  .pf-item[data-hidden] { display: none; }

  .pf-img-wrap {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #e0e0e0;
  }

  .pf-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
  }

  .pf-item:hover .pf-img-wrap img { transform: scale(1.06); }

  .pf-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.75) 0%, transparent 55%);
    opacity: 0;
    display: flex;
    align-items: flex-end;
    padding: 16px;
    transition: opacity .3s;
  }

  .pf-item:hover .pf-overlay { opacity: 1; }

  .pf-overlay span {
    font-size: 13px;
    font-weight: 500;
    color: #fff;
    line-height: 1.3;
  }

  @media (max-width: 600px) {
    .portfolio-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const pfItems    = document.querySelectorAll<HTMLElement>('.pf-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const cat = btn.dataset.cat;
      pfItems.forEach(item => {
        const show = cat === 'all' || item.dataset.cat === cat;
        item.toggleAttribute('data-hidden', !show);
      });
    });
  });
</script>
