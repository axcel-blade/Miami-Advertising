---
const advertising = [
  'Logos, Letterheads, Envelopes, Business Cards',
  'Brochures, Magazines, Flyers, Leaflets, Booklets',
  'Banners, Signboards, Rollups, Popups, Backdrops',
  'E-Cards, Posters, Folders, Binders, Stamps',
  'Websites & Packaging',
  'Copywriting — Slogans, Advertorials',
  'Branding — Building, Consultancy, Management',
  'Campaign Planning & Photography',
  'Brand Reminders & Promotional Items',
];

const production = [
  'Digital Printing — Banners, Signboards, Rollups',
  'Signs — Exterior, Interior, Way Finding, LED',
  'Roll-Up Stands & Pop-Up Displays',
  'Exhibition Booths, Kiosks & Podiums',
  'Vehicle Graphics & Wrapping',
  'Show Cards, Store Displays & Light Boxes',
  'Billboard & Mupi Advertising',
  'Canvas, Glass Frames & Hanging Banners',
  'Flyer Holders & See-Thru Window Displays',
];

const marketing = [
  'Email, SMS & MMS Marketing',
  'Direct Marketing & Post Mailing',
  'Market Research & E-Branding',
  'Building a Customer-Focused Organisation',
  'Results-Driven & Defensive Marketing',
  'Strategic Brand Positioning',
  'Visual Merchandising — Window Displays & Signage',
  'Interior Displays & Cosmetic Promotions',
  'Customer Profitability Management',
];

const rawMiami = import.meta.glob<{ default: { src: string } }>(
  '../assets/miami/**/*.{jpg,jpeg,JPG,JPEG,png,PNG}',
  { eager: true }
);

function getClientImgs(folder: string, count: number) {
  return Object.entries(rawMiami)
    .filter(([k]) => k.includes(folder))
    .slice(0, count)
    .map(([, v]) => v.default.src);
}

const kfcImgs    = getClientImgs('/kfc/', 4);
const pizzaImgs  = getClientImgs('/pizza hut/', 4);
const hardeesImgs = getClientImgs('/Hardees/', 4);
---

<section class="services" id="services">

  <div class="services-intro">
    <div class="container">
      <span class="section-label">What We Do</span>
      <h2 class="section-title">Our <span>Sections</span></h2>
      <p class="section-body">Three specialized divisions working together to deliver complete brand solutions across Dubai and the UAE.</p>
    </div>
  </div>

  <!-- Advertising -->
  <div class="svc-block adv-block" id="advertising">
    <div class="container svc-inner">
      <div class="svc-text reveal">
        <div class="svc-label">
          <span class="svc-tag">01</span>
          <span class="svc-name">ADVERTISING</span>
        </div>
        <h2 class="svc-title">Discover the Realm of Our<br /><strong>Advertising Capabilities</strong></h2>
        <p class="svc-desc">If you are a business with an image to keep, MIAMI is your answer. Below the line, above the line — we know exactly what you need. We are creative, we are smart, and we develop our trade to an art.</p>
        <ul class="svc-list">
          {advertising.map(item => <li><span class="list-arrow">›</span>{item}</li>)}
        </ul>
      </div>
      <div class="svc-imgs reveal" aria-label="KFC advertising work samples">
        {kfcImgs.length > 0 ? (
          <div class="img-mosaic">
            {kfcImgs.map((src, i) => (
              <div class={`img-cell ic${i}`}>
                <img src={src} alt="KFC — Miami Advertising work" loading="lazy" />
              </div>
            ))}
            <div class="client-badge adv-badge">KFC</div>
          </div>
        ) : (
          <div class="deco-grid">
            {Array.from({length: 9}).map((_, i) => <div class={`deco-cell c${i}`}></div>)}
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Production -->
  <div class="svc-block prod-block" id="production">
    <div class="container svc-inner reverse">
      <div class="svc-imgs reveal" aria-label="Pizza Hut production work samples">
        {pizzaImgs.length > 0 ? (
          <div class="img-mosaic">
            {pizzaImgs.map((src, i) => (
              <div class={`img-cell ic${i}`}>
                <img src={src} alt="Pizza Hut — Miami Advertising work" loading="lazy" />
              </div>
            ))}
            <div class="client-badge prod-badge">Pizza Hut</div>
          </div>
        ) : (
          <div class="deco-grid">
            {Array.from({length: 9}).map((_, i) => <div class={`deco-cell c${i}`}></div>)}
          </div>
        )}
      </div>
      <div class="svc-text reveal">
        <div class="svc-label">
          <span class="svc-tag">02</span>
          <span class="svc-name">PRODUCTION</span>
        </div>
        <h2 class="svc-title">Your Business is at the Heart of<br /><strong>Our Business</strong></h2>
        <p class="svc-desc">We trek mountains to bring solutions to all our clients. MIAMI has a network of reliable third-party suppliers who offer high quality products at great value for money across Dubai and the Emirates.</p>
        <ul class="svc-list">
          {production.map(item => <li><span class="list-arrow">›</span>{item}</li>)}
        </ul>
      </div>
    </div>
  </div>

  <!-- Marketing -->
  <div class="svc-block mkt-block" id="marketing">
    <div class="container svc-inner">
      <div class="svc-text reveal">
        <div class="svc-label">
          <span class="svc-tag">03</span>
          <span class="svc-name">MARKETING &amp; VISUAL MERCHANDISING</span>
        </div>
        <h2 class="svc-title">We Understand Your<br /><strong>Business Needs</strong></h2>
        <p class="svc-desc">We keep an eye on market trends and industry evolution to tailor-make the ideal marketing plan that fits your budget and guarantees your organisation a positive return on investment in Dubai's competitive market.</p>
        <ul class="svc-list">
          {marketing.map(item => <li><span class="list-arrow">›</span>{item}</li>)}
        </ul>
      </div>
      <div class="svc-imgs reveal" aria-label="Hardees marketing work samples">
        {hardeesImgs.length > 0 ? (
          <div class="img-mosaic">
            {hardeesImgs.map((src, i) => (
              <div class={`img-cell ic${i}`}>
                <img src={src} alt="Hardees — Miami Advertising work" loading="lazy" />
              </div>
            ))}
            <div class="client-badge mkt-badge">Hardees</div>
          </div>
        ) : (
          <div class="deco-grid">
            {Array.from({length: 9}).map((_, i) => <div class={`deco-cell c${i}`}></div>)}
          </div>
        )}
      </div>
    </div>
  </div>

</section>

<style>
  .services { background: var(--clr-white); }

  .services-intro {
    padding: var(--section-py) 0 40px;
    text-align: center;
  }

  .services-intro .section-body { margin-inline: auto; }

  .svc-block { padding: 80px 0; }

  .adv-block { background: #fafafa; }
  .prod-block { background: #f0faf5; }
  .mkt-block  { background: #fffdf0; }

  .svc-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .svc-inner.reverse { direction: rtl; }
  .svc-inner.reverse > * { direction: ltr; }

  .svc-label {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .svc-tag {
    font-family: var(--font-head);
    font-size: 40px;
    font-weight: 700;
    line-height: 1;
    opacity: .12;
    color: var(--clr-dark);
  }

  .svc-name {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
  }

  .adv-block .svc-name  { color: var(--clr-red); }
  .prod-block .svc-name { color: var(--clr-green); }
  .mkt-block .svc-name  { color: var(--clr-orange); }

  .svc-title {
    font-family: var(--font-head);
    font-size: clamp(26px, 3.5vw, 40px);
    line-height: 1.2;
    margin-bottom: 16px;
    color: var(--clr-dark);
  }

  .svc-title strong { display: block; }
  .adv-block  .svc-title strong { color: var(--clr-red); }
  .prod-block .svc-title strong { color: var(--clr-green); }
  .mkt-block  .svc-title strong { color: var(--clr-orange); }

  .svc-desc {
    font-size: 15px;
    color: var(--clr-mid);
    line-height: 1.8;
    margin-bottom: 28px;
    max-width: 500px;
  }

  .svc-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 16px;
  }

  .svc-list li {
    font-size: 14px;
    color: var(--clr-mid);
    display: flex;
    gap: 6px;
    align-items: flex-start;
  }

  .list-arrow {
    font-weight: 700;
    margin-top: -1px;
    flex-shrink: 0;
  }

  .adv-block  .list-arrow { color: var(--clr-red); }
  .prod-block .list-arrow { color: var(--clr-green); }
  .mkt-block  .list-arrow { color: var(--clr-orange); }

  /* Image mosaic */
  .svc-imgs { display: flex; justify-content: center; align-items: center; }

  .img-mosaic {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 6px;
    width: 100%;
    max-width: 460px;
    aspect-ratio: 1;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 48px rgba(0,0,0,.15);
  }

  .img-cell {
    overflow: hidden;
    background: #e0e0e0;
  }

  .img-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
  }

  .img-cell:hover img { transform: scale(1.08); }

  .client-badge {
    position: absolute;
    bottom: 14px; right: 14px;
    color: #fff;
    font-family: var(--font-head);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 8px 16px;
    border-radius: 6px;
    backdrop-filter: blur(4px);
  }

  .adv-badge  { background: rgba(224,0,0,.85); }
  .prod-badge { background: rgba(0,171,68,.85); }
  .mkt-badge  { background: rgba(181,0,85,.85); }

  /* Deco fallback */
  .deco-grid {
    display: grid;
    grid-template-columns: repeat(3, 120px);
    grid-template-rows: repeat(3, 120px);
    gap: 4px;
  }

  .deco-cell {
    clip-path: polygon(0 100%, 50% 0, 100% 100%);
    opacity: .7;
  }

  .adv-block .deco-cell:nth-child(odd)  { background: #e00000; }
  .adv-block .deco-cell:nth-child(even) { background: #9d0057; clip-path: polygon(0 0, 100% 0, 50% 100%); }
  .prod-block .deco-cell:nth-child(odd)  { background: #006f6b; }
  .prod-block .deco-cell:nth-child(even) { background: #00ab44; clip-path: polygon(0 0, 100% 0, 50% 100%); }
  .mkt-block .deco-cell:nth-child(odd)  { background: #f3cf00; }
  .mkt-block .deco-cell:nth-child(even) { background: #4fad02; clip-path: polygon(0 0, 100% 0, 50% 100%); }

  @media (max-width: 900px) {
    .svc-inner, .svc-inner.reverse {
      grid-template-columns: 1fr;
      direction: ltr;
    }
    .svc-imgs { display: none; }
    .svc-list { grid-template-columns: 1fr; }
  }
</style>
