---
const clients = [
  'RTA', 'HSBC', "IT&LY Hair Fashion", 'SQJT', 'Dubai Islamic Bank',
  'ADPC', 'Dar Al Ber Society', 'Total', 'Topcon', 'Harvey Nichols',
  'Paris Gallery', 'Salam', 'Dunhill London', 'Aswaaq', 'City of Arabia',
  'Mazda', 'Bayer HealthCare', 'Roche', 'Roccobarocco', 'Infinity TV',
  'Imdad', 'Burger King', 'Texas', 'Mega Wraps',
];
---

<section class="clients" id="clients">
  <div class="container">
    <div class="clients-header reveal">
      <span class="section-label">Trusted By</span>
      <h2 class="section-title">Our <span>Clients</span></h2>
      <p class="section-body">We have proudly served leading regional and international brands across multiple industries.</p>
    </div>

    <div class="clients-grid reveal">
      {clients.map(name => (
        <div class="client-card">
          <div class="client-initials">{name.split(' ').slice(0,2).map(w => w[0]).join('').toUpperCase().slice(0,2)}</div>
          <span class="client-name">{name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .clients {
    padding: var(--section-py) 0;
    background: var(--clr-dark);
  }

  .clients-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .clients-header .section-title { color: #fff; }
  .clients-header .section-body  { color: rgba(255,255,255,.5); margin-inline: auto; }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
  }

  .client-card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 8px;
    padding: 24px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    transition: background .2s, border-color .2s, transform .2s;
  }

  .client-card:hover {
    background: rgba(228,23,75,.12);
    border-color: rgba(228,23,75,.3);
    transform: translateY(-4px);
  }

  .client-initials {
    width: 48px; height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--clr-accent), #f4a261);
    display: grid;
    place-items: center;
    font-family: var(--font-head);
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .client-name {
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,.7);
    text-align: center;
    letter-spacing: .5px;
    line-height: 1.3;
  }

  @media (max-width: 480px) {
    .clients-grid { grid-template-columns: repeat(3, 1fr); }
    .client-card  { padding: 16px 10px; }
  }
</style>
