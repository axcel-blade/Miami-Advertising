---
import logoSrc from '../assets/miami/logo-06.jpg';

const rawMiami = import.meta.glob<{ default: { src: string } }>(
  '../assets/miami/**/*.{jpg,jpeg,JPG,JPEG,png,PNG}',
  { eager: true }
);

const heroImages = Object.entries(rawMiami)
  .filter(([k]) =>
    k.includes('/pizza hut/') || k.includes('/kfc/') || k.includes('/Hardees/')
  )
  .slice(0, 6)
  .map(([, v]) => v.default.src);
---

<section class="hero" id="home">
  <div class="hero-geo" aria-hidden="true">
    <div class="geo-tri t1"></div>
    <div class="geo-tri t2"></div>
    <div class="geo-tri t3"></div>
    <div class="geo-tri t4"></div>
    <div class="geo-tri t5"></div>
    <div class="geo-tri t6"></div>
    <div class="geo-tri t7"></div>
    <div class="geo-tri t8"></div>
  </div>

  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-logo">
        <img src={logoSrc.src} alt="Miami Advertising logo" class="hero-logo-img" />
        <span class="hero-wordmark">
          <span class="hwm-miami">MIAMI</span>
          <span class="hwm-adv">ADVERTISING</span>
        </span>
      </div>

      <h1 class="hero-tagline">EMPOWER<br /><em>YOUR BRAND</em></h1>

      <p class="hero-sub">
        Dubai's premier advertising, production, marketing &amp; event management agency — delivering world-class creative solutions across the UAE.
      </p>

      <div class="hero-actions">
        <a href="#services" class="btn-primary">Our Services</a>
        <a href="#portfolio" class="btn-outline">View Portfolio</a>
      </div>

      <div class="hero-contact-strip">
        <span><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z"/></svg>+971 6 542 0994</span>
        <span><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>info@miamiadv.ae</span>
        <span><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7zm0 9.5c-1.4 0-2.5-1.1-2.5-2.5S10.6 6.5 12 6.5s2.5 1.1 2.5 2.5S13.4 11.5 12 11.5z"/></svg>Dubai, UAE</span>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      {heroImages.length > 0 ? (
        <div class="hero-mosaic">
          {heroImages.map((src, i) => (
            <div class={`mosaic-cell mc${i}`}>
              <img src={src} alt="" loading="eager" />
            </div>
          ))}
        </div>
      ) : (
        <div class="x-graphic">
          <div class="x-bar x1"></div>
          <div class="x-bar x2"></div>
          <div class="x-bar x3"></div>
          <div class="x-bar x4"></div>
        </div>
      )}
    </div>
  </div>

  <div class="hero-scroll">
    <span>Scroll down</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    background: #0f0f0f;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-geo {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .geo-tri {
    position: absolute;
    width: 0; height: 0;
  }

  .t1 { border-left: 300px solid transparent; border-bottom: 300px solid rgba(181,0,85,.08); top: -50px; left: -60px; }
  .t2 { border-right: 250px solid transparent; border-top: 250px solid rgba(0,111,107,.06); top: 0; right: 40%; }
  .t3 { border-left: 200px solid transparent; border-bottom: 200px solid rgba(0,73,151,.07); bottom: 10%; left: 20%; }
  .t4 { border-right: 180px solid transparent; border-bottom: 180px solid rgba(99,25,133,.05); top: 30%; left: 5%; }
  .t5 { border-left: 350px solid transparent; border-top: 350px solid rgba(224,0,0,.04); bottom: -80px; right: 30%; }
  .t6 { border-right: 120px solid transparent; border-top: 120px solid rgba(255,255,255,.03); top: 20%; left: 50%; }
  .t7 { border-left: 140px solid transparent; border-bottom: 140px solid rgba(0,171,68,.05); bottom: 20%; right: 10%; }
  .t8 { border-right: 90px solid transparent; border-bottom: 90px solid rgba(243,207,0,.06); top: 60%; left: 35%; }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    padding-top: 100px;
    padding-bottom: 60px;
  }

  .hero-logo {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 32px;
  }

  .hero-logo-img {
    height: 80px;
    width: 80px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .hero-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1;
    gap: 4px;
  }

  .hwm-miami {
    font-family: var(--font-head);
    font-size: 42px;
    font-weight: 700;
    letter-spacing: 6px;
    color: #fff;
  }

  .hwm-adv {
    font-family: var(--font-head);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 6px;
    color: rgba(255,255,255,.65);
  }

  .hero-tagline {
    font-family: var(--font-head);
    font-size: clamp(44px, 7vw, 80px);
    font-weight: 700;
    color: #fff;
    line-height: 1;
    letter-spacing: -1px;
    margin-bottom: 20px;
  }

  .hero-tagline em {
    font-style: normal;
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 16px;
    color: rgba(255,255,255,.55);
    max-width: 420px;
    line-height: 1.7;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .btn-primary {
    background: var(--clr-accent);
    color: #fff;
    padding: 14px 32px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: .5px;
    transition: background .2s, transform .2s;
  }
  .btn-primary:hover { background: #8a003e; transform: translateY(-2px); }

  .btn-outline {
    border: 1.5px solid rgba(255,255,255,.3);
    color: #fff;
    padding: 14px 32px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: .5px;
    transition: border-color .2s, background .2s, transform .2s;
  }
  .btn-outline:hover { border-color: #fff; background: rgba(255,255,255,.06); transform: translateY(-2px); }

  .hero-contact-strip {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }

  .hero-contact-strip span {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: rgba(255,255,255,.45);
  }

  .hero-contact-strip svg { flex-shrink: 0; opacity: .6; }

  /* Mosaic image grid */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 500px;
  }

  .hero-mosaic {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 8px;
    width: 100%;
    height: 100%;
    border-radius: 12px;
    overflow: hidden;
  }

  .mosaic-cell {
    overflow: hidden;
    position: relative;
  }

  .mosaic-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
  }

  .mosaic-cell:hover img { transform: scale(1.08); }

  .mc0 { grid-column: 1 / 3; grid-row: 1; }
  .mc3 { grid-column: 1; grid-row: 2; }
  .mc5 { grid-column: 2 / 4; grid-row: 2; }

  /* X graphic fallback */
  .x-graphic {
    position: relative;
    width: 400px;
    height: 400px;
  }

  .x-bar {
    position: absolute;
    border-radius: 6px;
    opacity: .9;
  }

  .x1 {
    width: 60px; height: 380px;
    background: linear-gradient(180deg, #b50055, #9d0057, #631985, #401d81);
    top: 10px; left: 80px;
    transform: rotate(-45deg) translateY(-20px);
    transform-origin: top center;
  }

  .x2 {
    width: 60px; height: 380px;
    background: linear-gradient(180deg, #401d81, #004997, #00629e, #006f6b);
    top: 10px; left: 260px;
    transform: rotate(45deg) translateY(-20px);
    transform-origin: top center;
  }

  .x3 {
    width: 60px; height: 220px;
    background: linear-gradient(180deg, #e00000, #9d0057, #b50055, #631985);
    bottom: 10px; left: 80px;
    transform: rotate(45deg) translateY(20px);
    transform-origin: bottom center;
  }

  .x4 {
    width: 60px; height: 220px;
    background: linear-gradient(180deg, #006f6b, #00ab44, #4fad02, #f3cf00);
    bottom: 10px; left: 260px;
    transform: rotate(-45deg) translateY(20px);
    transform-origin: bottom center;
  }

  .hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 1;
  }

  .hero-scroll span {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,.3);
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, rgba(255,255,255,.3), transparent);
    animation: scrollPulse 2s ease infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: .3; transform: scaleY(1); }
    50% { opacity: .8; transform: scaleY(1.2); }
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
  }

  @media (max-width: 480px) {
    .hero-contact-strip { gap: 16px; }
    .hero-contact-strip span { font-size: 12px; }
  }
</style>
