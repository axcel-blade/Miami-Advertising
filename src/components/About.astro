---
import printImg from '../assets/production-printing-press.jpg';
import factoryImg from '../assets/production-modern-factory.jpg';
---

<section class="about" id="about">
  <div class="container about-grid">
    <div class="about-text reveal">
      <span class="section-label">Who We Are</span>
      <h2 class="section-title">A Welcome <span>Note</span></h2>
      <p class="section-body">
        MIAMI is a Dubai-based advertising, production, marketing and event management company.
        We are dedicated to offering our clients the best value for their identity by taking a comprehensive
        approach to their needs.
      </p>

      <div class="about-image-inline reveal">
        <img src={printImg.src} alt="State-of-the-art printing production" />
        <div class="img-caption">State-of-the-art production &amp; printing</div>
      </div>

      <p class="section-body" style="margin-top:24px">
        Our commitment is to extend world-class service, high quality results, and innovation. We build
        complete and comprehensive business solutions to help clients manage their corporate identity
        across Dubai and the wider UAE.
      </p>

      <div class="about-stats">
        <div class="stat">
          <span class="stat-num">20+</span>
          <span class="stat-lbl">Years Experience</span>
        </div>
        <div class="stat">
          <span class="stat-num">3</span>
          <span class="stat-lbl">Core Divisions</span>
        </div>
        <div class="stat">
          <span class="stat-num">24+</span>
          <span class="stat-lbl">Major Clients</span>
        </div>
      </div>
    </div>

    <div class="about-right reveal">
      <div class="about-hero-img">
        <img src={factoryImg.src} alt="Miami Advertising — manufacturing facility" />
        <div class="img-overlay-badge">
          <span class="badge-num">Dubai</span>
          <span class="badge-lbl">UAE</span>
        </div>
      </div>

      <div class="about-cards">
        <div class="about-card mission">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Mission</h3>
          <p>We strive to provide best-in-class services while creating a workplace environment that attracts exceptional and talented individuals, together bringing our art to perfection.</p>
        </div>

        <div class="about-card vision">
          <div class="card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3>Vision</h3>
          <p>MIAMI aspires to be regionally recognized as a highly creative and dedicated branding consultancy — the ideal business partner for all your advertising, production, event and marketing needs in Dubai.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: var(--section-py) 0;
    background: var(--clr-light);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .about-image-inline {
    margin: 28px 0 0;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 4px 24px rgba(0,0,0,.12);
  }

  .about-image-inline img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
  }

  .img-caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(0,0,0,.7), transparent);
    color: #fff;
    font-size: 12px;
    letter-spacing: 1px;
    padding: 16px 14px 10px;
    text-transform: uppercase;
  }

  .about-stats {
    display: flex;
    gap: 32px;
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid #e0e0e0;
  }

  .stat { display: flex; flex-direction: column; gap: 4px; }

  .stat-num {
    font-family: var(--font-head);
    font-size: 40px;
    font-weight: 700;
    color: var(--clr-accent);
    line-height: 1;
  }

  .stat-lbl {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--clr-mid);
  }

  /* Right column */
  .about-right {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .about-hero-img {
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 8px 40px rgba(0,0,0,.15);
  }

  .about-hero-img img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
    transition: transform .4s ease;
  }

  .about-hero-img:hover img { transform: scale(1.04); }

  .img-overlay-badge {
    position: absolute;
    top: 16px; right: 16px;
    background: var(--clr-accent);
    color: #fff;
    border-radius: 8px;
    padding: 10px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .badge-num {
    font-family: var(--font-head);
    font-size: 18px;
    font-weight: 700;
    line-height: 1;
  }

  .badge-lbl {
    font-size: 10px;
    letter-spacing: 2px;
    opacity: .85;
  }

  .about-cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .about-card {
    background: var(--clr-white);
    border-radius: 8px;
    padding: 24px;
    border-left: 4px solid transparent;
    box-shadow: 0 2px 16px rgba(0,0,0,.06);
    transition: transform .2s, box-shadow .2s;
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .about-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(0,0,0,.1); }

  .about-card.mission { border-left-color: var(--clr-accent); }
  .about-card.vision  { border-left-color: var(--clr-green); }

  .card-icon {
    width: 48px; height: 48px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  .mission .card-icon { background: rgba(228,23,75,.08); color: var(--clr-accent); }
  .vision  .card-icon { background: rgba(42,122,42,.08); color: var(--clr-green); }

  .about-card > div { flex: 1; }

  .about-card h3 {
    font-family: var(--font-head);
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--clr-dark);
  }

  .about-card p {
    font-size: 14px;
    color: var(--clr-mid);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .about-stats { gap: 24px; }
  }
</style>
